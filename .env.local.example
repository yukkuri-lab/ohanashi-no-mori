# ⑨ 必須環境変数の一覧
# このファイルをコピーして .env.local にリネームし、値を入力してください
# .env.local は .gitignore に入っているので GitHub には上がりません

# Google Cloud Text-to-Speech API キー（必須）
# 取得方法: https://console.cloud.google.com/ → API と サービス → 認証情報
GOOGLE_TTS_API_KEY=ここにAPIキーを貼り付ける

# 音声APIを呼び出せるオリジン（本番URLに変更する。カンマ区切りで複数可）
# 例: ALLOWED_ORIGIN=https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:3000
